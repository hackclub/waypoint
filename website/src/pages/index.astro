---
import Navigation from '../components/Navigation.astro';
import Button from '../components/Button.astro';
import BlueprintBackground from '../components/BlueprintBackground.astro';
import { SITE_LOADER_CSS, SITE_LOADER_SCRIPT } from '../lib/site-loader.mjs';
import { IMAGES, LINKS } from '../config';

const GUIDES_URL = LINKS.guides;
const SITE_URL = 'https://waypoint.hackclub.com/';
const SITE_TITLE = 'Waypoint';
const SITE_DESCRIPTION =
  'A Hack Club YSWS where students design a PCB, chassis, and starter ROS2 package, then bring a real robot to life.';
const SHARE_IMAGE_URL = new URL(IMAGES.starHero, SITE_URL).toString();
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href={IMAGES.starHero} />
    <link rel="shortcut icon" href={IMAGES.starHero} />
    <link rel="apple-touch-icon" href={IMAGES.starHero} />
    <link rel="canonical" href={SITE_URL} />
    <title>Waypoint!</title>
    <meta name="description" content={SITE_DESCRIPTION} />
    <meta name="theme-color" content="#141414" />
    <meta property="og:site_name" content="Hack Club Waypoint" />
    <meta property="og:title" content={SITE_TITLE} />
    <meta property="og:description" content={SITE_DESCRIPTION} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={SITE_URL} />
    <meta property="og:image" content={SHARE_IMAGE_URL} />
    <meta property="og:image:alt" content="Waypoint star logo" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={SITE_TITLE} />
    <meta name="twitter:description" content={SITE_DESCRIPTION} />
    <meta name="twitter:image" content={SHARE_IMAGE_URL} />
    <style set:html={SITE_LOADER_CSS}></style>
    <script set:html={SITE_LOADER_SCRIPT}></script>

    <style is:global>
      @import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&family=IBM+Plex+Mono:wght@400;500;600&display=swap');

      :root {
        --bg: #141414;
        --ink: #f2e5b7;
        --gold: #f0b323;
        --red: #d84b3a;
        --hero-progress: 0;
        --hero-offset: 0px;
        --hero-text-parallax: 0px;
        --hero-art-parallax: 0px;
        --scroll-cue-opacity: 1;
        --hero-viewport: 100vh;
        --hero-overlap: 80vh;
        --hero-art-top: 0rem;
        --hero-heidi-x: 11.05%;
        --hero-heidi-y: 30.97%;
        --hero-heidi-width: 47.62%;
        --hero-robot-x: 28.52%;
        --hero-robot-y: 51.25%;
        --hero-robot-width: 15.78%;
      }

      @supports (height: 100svh) {
        :root {
          --hero-viewport: 100svh;
          --hero-overlap: 80svh;
        }
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
        overflow-x: hidden;
      }

      body {
        margin: 0;
        background: var(--bg);
        color: var(--ink);
        font-family: 'IBM Plex Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
        overflow-x: hidden;
        overflow-y: auto;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        display: block;
        max-width: 100%;
      }

      .pixel-font {
        font-family: 'Press Start 2P', monospace;
      }

      .page {
        position: relative;
        min-height: 100vh;
        width: 100%;
        max-width: 100%;
        background: var(--bg);
      }

      .shell {
        position: relative;
        z-index: 1;
        width: 100%;
        max-width: 100%;
      }

      .hero-section {
        position: relative;
        height: calc(var(--hero-viewport) + var(--hero-overlap));
        width: 100%;
        max-width: 100%;
      }

      .hero-sticky {
        position: sticky;
        top: 0;
        height: var(--hero-viewport);
        width: 100%;
        max-width: 100%;
        overflow: visible;
      }

      .hero-inner {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: var(--hero-viewport);
        width: 100%;
        max-width: 100%;
        overflow: visible;
      }

      .hero-copy {
        position: absolute;
        z-index: 4;
        width: min(100%, 920px);
        padding-inline: clamp(1rem, 5vw, 2rem);
        text-align: center;
        transform: translate3d(0, calc(-120px + var(--hero-text-parallax)), 0);
        will-change: transform;
        pointer-events: none;
        user-select: none;
        -webkit-user-select: none;
      }

      .eyebrow {
        display: none;
      }

      .hero-title {
        margin: 0;
        font-size: clamp(2.4rem, 8vw, 5.6rem);
        line-height: 1.25;
        text-transform: uppercase;
        overflow-wrap: anywhere;
      }

      .hero-subtitle {
        display: block;
        margin: 1.5rem auto 0;
        max-width: min(760px, calc(100% - 3rem));
        font-size: clamp(0.9rem, 2vw, 1.08rem);
        line-height: 1.9;
        color: color-mix(in srgb, var(--ink) 92%, var(--bg));
      }

      .hero-figure {
        position: absolute;
        left: 50%;
        top: 50%;
        z-index: 2;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100vw;
        width: 100dvw;
        max-width: 100%;
        height: var(--hero-viewport);
        overflow: visible;
        transform: translate3d(-50%, calc(-50% + var(--hero-offset)), 0);
        will-change: transform;
        pointer-events: none;
      }

      .hero-art {
        position: absolute;
        top: var(--hero-art-top);
        left: 50%;
        z-index: 1;
        width: max(980px, 118vw);
        aspect-ratio: 16 / 9;
        transform: translate3d(-50%, var(--hero-art-parallax), 0);
        will-change: transform;
        pointer-events: none;
        user-select: none;
        -webkit-user-select: none;
      }

      .hero-art__layer {
        position: absolute;
        display: block;
      }

      .hero-art__layer--background {
        inset: 0;
        z-index: 1;
        width: 100%;
        height: 100%;
        object-fit: contain;
      }

      .hero-art__layer--heidi {
        top: var(--hero-heidi-y);
        left: var(--hero-heidi-x);
        z-index: 3;
        width: var(--hero-heidi-width);
        height: auto;
      }

      .hero-art__layer--robot {
        top: var(--hero-robot-y);
        left: var(--hero-robot-x);
        z-index: 2;
        width: var(--hero-robot-width);
        height: auto;
      }

      .hill-star {
        position: absolute;
        top: clamp(4rem, 10vh, 7rem);
        right: clamp(8rem, 15vw, 13rem);
        width: clamp(72px, 7vw, 104px);
        z-index: 3;
        transform-origin: center;
        animation: starTilt 6s ease-in-out infinite;
        filter: drop-shadow(0 0 0.75rem rgba(240, 179, 35, 0.28));
        pointer-events: none;
        user-select: none;
        -webkit-user-select: none;
      }

      .hill-star img {
        width: 100%;
        height: auto;
        display: block;
      }

      .scroll-cue {
        position: absolute;
        left: 50%;
        bottom: calc(100% + 1.45rem);
        z-index: 2147483000;
        width: 58px;
        opacity: var(--scroll-cue-opacity);
        transform: translateX(-50%);
        filter: drop-shadow(3px 3px 0 rgba(20, 20, 20, 0.55));
        cursor: pointer;
        user-select: none;
        -webkit-user-select: none;
        transition:
          transform 220ms cubic-bezier(0.34, 1.56, 0.64, 1),
          opacity 180ms ease,
          filter 180ms ease;
        will-change: transform, opacity;
      }

      .scroll-cue img {
        width: 100%;
        height: auto;
        display: block;
        transform-origin: 50% 55%;
        animation: scrollCueCall 1.28s cubic-bezier(0.34, 1.56, 0.64, 1) infinite;
        will-change: transform;
      }

      .scroll-cue:hover {
        transform: translateX(-50%) translateY(-0.35rem);
        filter: drop-shadow(4px 5px 0 rgba(20, 20, 20, 0.55));
      }

      .scroll-cue:focus-visible {
        outline: 2px solid var(--gold);
        outline-offset: 0.45rem;
      }

      .hero-title,
      .hero-art img,
      .hill-star img,
      .scroll-cue img {
        user-select: none;
        -webkit-user-select: none;
        -webkit-user-drag: none;
        pointer-events: none;
      }

      .foreground-hill {
        position: absolute;
        left: 0;
        bottom: calc(100% - var(--foreground-cover-height));
        z-index: -1;
        display: flex;
        align-items: flex-end;
        justify-content: center;
        width: 100%;
        min-width: 100%;
        height: clamp(220px, 34vh, 420px);
        overflow: hidden;
        pointer-events: none;
      }

      .foreground-hill svg {
        width: auto;
        min-width: max(720px, 120vw);
        height: 100%;
        display: block;
        flex: 0 0 auto;
      }

      .content {
        --foreground-cover-height: 20px;
        position: relative;
        isolation: isolate;
        z-index: 11;
        margin-top: calc(-1 * var(--hero-overlap));
        padding: 0 1.25rem 0;
        background: transparent;
        width: 100%;
        max-width: 100%;
        pointer-events: auto;
      }

      .content::before {
        content: '';
        position: absolute;
        inset: calc(-1 * var(--foreground-cover-height)) 0 0;
        z-index: 0;
        background: var(--bg);
      }

      .content-inner {
        position: relative;
        z-index: 1;
        width: min(900px, 100%);
        margin: 0 auto;
      }

      .divider {
        height: 2px;
        background: var(--ink);
        opacity: 0.9;
      }

      .section {
        padding: 3.5rem 0 0;
      }

      .section-kicker {
        font-size: 0.74rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--red);
      }

      .section-title {
        margin: 1rem 0 0;
        font-size: clamp(1.2rem, 3vw, 1.8rem);
        line-height: 1.9;
        text-transform: uppercase;
        overflow-wrap: anywhere;
      }

      .section-text {
        margin-top: 1.5rem;
        font-size: 1rem;
        line-height: 2;
      }

      .steps {
        display: grid;
        gap: 1.7rem;
        margin-top: 2rem;
      }

      .step {
        display: grid;
        grid-template-columns: 3.4rem 1fr;
        gap: 1rem;
        align-items: start;
        min-width: 0;
      }

      .step > div {
        min-width: 0;
      }

      .step-number {
        font-size: 0.8rem;
        line-height: 2;
        color: var(--gold);
      }

      .step-title {
        font-size: 0.85rem;
        line-height: 1.9;
        text-transform: uppercase;
      }

      .step-body {
        margin-top: 0.55rem;
        font-size: 0.98rem;
        line-height: 1.95;
      }

      .center-button {
        display: flex;
        justify-content: center;
        padding-top: 2rem;
      }

      .bullet-list {
        padding: 0;
        margin: 1.4rem 0 0;
        list-style: none;
      }

      .bullet-list li {
        margin-top: 0.9rem;
        font-size: 1rem;
        line-height: 2;
      }

      .muted-note {
        color: color-mix(in srgb, var(--ink) 86%, var(--bg));
      }

      .site-footer {
        margin-top: 4rem;
        padding: 1.15rem 0 1.25rem;
        border-top: 1px solid color-mix(in srgb, var(--ink) 28%, var(--bg));
        color: color-mix(in srgb, var(--ink) 58%, var(--bg));
        font-size: 0.82rem;
        line-height: 1.8;
        text-align: center;
      }

      .site-footer strong {
        color: color-mix(in srgb, var(--gold) 68%, var(--bg));
        font-weight: 600;
      }

      @keyframes starTilt {
        0%, 100% { transform: rotate(-7deg) translateY(0px); }
        50% { transform: rotate(7deg) translateY(-4px); }
      }

      @keyframes scrollCueCall {
        0%,
        100% {
          transform: translateY(-7px) scale(1);
        }
        35% {
          transform: translateY(13px) scale(1.08, 0.92);
        }
        52% {
          transform: translateY(1px) scale(0.96, 1.06);
        }
        72% {
          transform: translateY(6px) scale(1.02, 0.98);
        }
      }

      @keyframes scrollCueQuiet {
        0%,
        100% {
          transform: translateY(-3px);
        }
        50% {
          transform: translateY(5px);
        }
      }

      @media (max-width: 720px) {
        .hero-inner {
          padding-top: 8.4rem;
        }

        .hero-figure {
          width: 100vw;
          width: 100dvw;
          max-width: none;
          top: 58%;
        }

        .hero-art {
          --hero-art-top: 10.5rem;
          width: clamp(760px, 150vw, 940px);
        }

        .content {
          padding-inline: clamp(0.9rem, 4vw, 1.1rem);
        }

        .hill-star {
          top: 5.25rem;
          right: 4.25rem;
          width: 64px;
        }

        .step {
          grid-template-columns: 1fr;
          gap: 0.4rem;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }

        .hill-star {
          animation-duration: 12s;
        }

        .scroll-cue {
          transform: translateX(-50%);
        }

        .scroll-cue img {
          animation: scrollCueQuiet 2.1s ease-in-out infinite;
        }

        .hero-copy,
        .hero-figure {
          transition: none;
        }

        .hero-figure {
          transform: translate3d(-50%, calc(-50% + var(--hero-offset)), 0);
        }

        .hero-art {
          transform: translate3d(-50%, 0, 0);
        }
      }
    </style>
  </head>

  <body>
    <div class="page">
      <BlueprintBackground />

      <Navigation />

      <div class="shell">
        <section class="hero-section" data-hero>
          <div class="hero-sticky">
            <div class="hero-inner">
              <div class="hero-figure" aria-hidden="true">
                <div class="hero-art">
                  <img class="hero-art__layer hero-art__layer--background" src={IMAGES.heroBackground} alt="" />
                  <img class="hero-art__layer hero-art__layer--heidi" src={IMAGES.heroHeidi} alt="" />
                  <img class="hero-art__layer hero-art__layer--robot" src={IMAGES.heroRobot} alt="" />
                </div>

                <div class="hero-copy">
                  <h1 class="hero-title pixel-font">Waypoint</h1>
                </div>

                <div class="hill-star">
                  <img src={IMAGES.starHero} alt="Waypoint star decoration" />
                </div>

              </div>
            </div>
          </div>
        </section>

        <main class="content">
          <div class="foreground-hill" aria-hidden="true">
            <svg viewBox="0 0 1440 480" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" width="1600" height="600">
              <path
                d="M0 330C110 284 177 263 265 263C369 263 431 304 517 304C623 304 726 225 840 225C946 225 1004 273 1107 273C1206 273 1297 226 1440 166V480H0V330Z"
                fill="var(--bg)"
                stroke="var(--ink)"
                stroke-width="2"
              />
              <path
                d="M0 340C121 292 191 277 274 277C366 277 430 315 521 315C635 315 726 239 841 239C954 239 1024 286 1115 286C1229 286 1317 236 1440 183"
                fill="none"
                stroke="var(--gold)"
                stroke-width="2"
                opacity="0.95"
              />
              <path
                d="M0 363C130 319 214 309 312 309C395 309 473 337 563 337C664 337 733 286 840 286C942 286 1040 324 1128 324C1233 324 1312 293 1440 229"
                fill="none"
                stroke="var(--red)"
                stroke-width="2"
                opacity="0.82"
              />
            </svg>
          </div>

          <div class="content-inner">
            <div class="divider" id="steps-route"></div>

            <a class="scroll-cue" href="#steps-title" aria-label="Scroll to the robot build steps">
              <img src="/images/waypoint/scroll-arrows.svg" alt="" />
            </a>

            <section class="section" aria-labelledby="steps-title" tabindex="-1">
              <div class="section-kicker pixel-font">01 02 03</div>
              <h2 id="steps-title" class="section-title pixel-font" tabindex="-1">Create a ROS2 robot</h2>

              

              <div class="steps">
                <article class="step">
                  <div class="step-number pixel-font">01</div>
                  <div>
                    <div class="step-title pixel-font">Design the control PCB</div>
                    <div class="step-body">
                      Build the custom board that powers your robot, drives motors, reads sensors, and acts as the center of the whole system.
                    </div>
                  </div>
                </article>

                <article class="step">
                  <div class="step-number pixel-font">02</div>
                  <div>
                    <div class="step-title pixel-font">Design the chassis</div>
                    <div class="step-body">
                      Design the body your robot lives in, from its looks to the way it moves through the world.
                    </div>
                  </div>
                </article>

                <article class="step">
                  <div class="step-number pixel-font">03</div>
                  <div>
                    <div class="step-title pixel-font">Build the starter ROS2 package</div>
                    <div class="step-body">
                      Give your robot a software starting point so its ready to become a real ROS2 build.
                    </div>
                  </div>
                </article>
              </div>

              <p class="section-text">
                Don't know where to start? Check out the guide for detailed instructions, tips, and resources!
              </p>

              <div class="center-button">
                <Button href={GUIDES_URL}>
                  Open the guide
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M5 12h14"></path>
                    <path d="M13 5l7 7-7 7"></path>
                  </svg>
                </Button>
              </div>
            </section>

            <section class="section" id="how-it-works" aria-labelledby="how-title">
              <div class="divider"></div>
              <div style="padding-top: 3rem;">
                <div class="section-kicker pixel-font">How it works</div>
                <h2 id="how-title" class="section-title pixel-font">What exactly is this?</h2>
                <p class="section-text">
                  Waypoint is a You Ship, We Ship (YSWS) where you design your own robot, give it code, and then we ship your design to you! Join the Slack to stay up to date, ask questions, and see what other people are building.
                </p>
              </div>
            </section>

            <footer class="site-footer">
              Made by Logan Peterson with <strong>&lt;3</strong>
            </footer>
          </div>
        </main>
      </div>
    </div>

    <script is:inline>
      const hero = document.querySelector('[data-hero]');
      const scrollCue = document.querySelector('.scroll-cue');
      const root = document.documentElement;
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      let targetProgress = 0;
      let currentProgress = 0;
      let targetTextParallax = 0;
      let currentTextParallax = 0;
      let targetArtParallax = 0;
      let currentArtParallax = 0;
      let targetScrollCueOpacity = 1;
      let currentScrollCueOpacity = 1;
      let rafId = 0;
      let scrollTweenId = 0;

      const measureTargets = () => {
        if (!hero) return;
        const rect = hero.getBoundingClientRect();
        const total = hero.offsetHeight - window.innerHeight;
        targetProgress = Math.max(0, Math.min(1, -rect.top / Math.max(total, 1)));
        targetTextParallax = -window.scrollY * 0.12;
        targetArtParallax = -window.scrollY * 0.045;
        targetScrollCueOpacity = Math.max(0, Math.min(1, 1 - targetProgress * 5));
      };

      const render = () => {
        const easing = prefersReducedMotion ? 1 : 0.14;
        currentProgress += (targetProgress - currentProgress) * easing;
        currentTextParallax += (targetTextParallax - currentTextParallax) * easing;
        currentArtParallax += (targetArtParallax - currentArtParallax) * easing;
        currentScrollCueOpacity += (targetScrollCueOpacity - currentScrollCueOpacity) * easing;

        if (Math.abs(targetProgress - currentProgress) < 0.0005) currentProgress = targetProgress;
        if (Math.abs(targetTextParallax - currentTextParallax) < 0.1) currentTextParallax = targetTextParallax;
        if (Math.abs(targetArtParallax - currentArtParallax) < 0.1) currentArtParallax = targetArtParallax;
        if (Math.abs(targetScrollCueOpacity - currentScrollCueOpacity) < 0.01) currentScrollCueOpacity = targetScrollCueOpacity;

        root.style.setProperty('--hero-progress', currentProgress.toFixed(4));
        root.style.setProperty('--hero-offset', `${(currentProgress * -40).toFixed(2)}px`);
        root.style.setProperty('--hero-text-parallax', `${currentTextParallax.toFixed(2)}px`);
        root.style.setProperty('--hero-art-parallax', `${currentArtParallax.toFixed(2)}px`);
        root.style.setProperty('--scroll-cue-opacity', currentScrollCueOpacity.toFixed(3));
        if (
          currentProgress !== targetProgress ||
          currentTextParallax !== targetTextParallax ||
          currentArtParallax !== targetArtParallax ||
          currentScrollCueOpacity !== targetScrollCueOpacity
        ) {
          rafId = window.requestAnimationFrame(render);
        } else {
          rafId = 0;
        }
      };

      const scheduleRender = () => {
        measureTargets();
        if (!rafId) rafId = window.requestAnimationFrame(render);
      };

      scheduleRender();
      window.addEventListener('scroll', scheduleRender, { passive: true });
      window.addEventListener('resize', scheduleRender);

      const easeOutCubic = (value) => 1 - Math.pow(1 - value, 3);

      const scrollToElement = (target) => {
        if (scrollTweenId) window.cancelAnimationFrame(scrollTweenId);

        const scroller = document.scrollingElement || document.documentElement;
        const start = scroller.scrollTop;
        const maxScroll = scroller.scrollHeight - window.innerHeight;
        const targetTop = Math.max(0, Math.min(maxScroll, target.getBoundingClientRect().top + window.scrollY));
        const distance = targetTop - start;
        const duration = prefersReducedMotion ? 420 : 1000;
        const startTime = performance.now();

        if (duration === 0 || Math.abs(distance) < 2) {
          scroller.scrollTop = targetTop;
          if (target instanceof HTMLElement) target.focus({ preventScroll: true });
          return;
        }

        const step = (time) => {
          const progress = Math.min(1, (time - startTime) / duration);
          scroller.scrollTop = start + distance * easeOutCubic(progress);

          if (progress < 1) {
            scrollTweenId = window.requestAnimationFrame(step);
            return;
          }

          scrollTweenId = 0;
          if (target instanceof HTMLElement) target.focus({ preventScroll: true });
          if (window.history?.replaceState && target.id) {
            window.history.replaceState(null, '', `#${target.id}`);
          }
        };

        scrollTweenId = window.requestAnimationFrame(step);
      };

      const cancelScrollTween = () => {
        if (!scrollTweenId) return;
        window.cancelAnimationFrame(scrollTweenId);
        scrollTweenId = 0;
      };

      scrollCue?.addEventListener('click', (event) => {
        const targetId = scrollCue.getAttribute('href');
        if (!targetId || !targetId.startsWith('#')) return;

        const target = document.querySelector(targetId);
        if (!target) return;

        event.preventDefault();
        scrollToElement(target);
      });

      window.addEventListener('wheel', cancelScrollTween, { passive: true });
      window.addEventListener('touchstart', cancelScrollTween, { passive: true });
      window.addEventListener('keydown', (event) => {
        if (['ArrowDown', 'ArrowUp', 'PageDown', 'PageUp', 'Home', 'End', ' '].includes(event.key)) {
          cancelScrollTween();
        }
      });
    </script>
  </body>
</html>
