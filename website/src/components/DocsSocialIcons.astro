---
import config from 'virtual:starlight/user-config';
import { Icon } from '@astrojs/starlight/components';

const links = config.social || [];
---

{
	links.length > 0 && (
		<div class="docs-social-links">
			<a
				href="https://hackclub.com"
				class="docs-social-flag"
				target="_blank"
				rel="noreferrer"
				aria-label="Hack Club"
			>
				<img src="/OrpheusFlag.svg" alt="Hack Club flag" />
			</a>

			{links.map(({ label, href, icon }) => (
				<a href={href} rel="me noreferrer" class="docs-social-link">
					<span class="sr-only">{label}</span>
					<Icon name={icon} />
				</a>
			))}
		</div>
	)
}

<style>
	@layer starlight.core {
		.docs-social-links {
			display: flex;
			gap: 0.7rem;
			align-items: flex-start;
		}

		.docs-social-link {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			width: 2.75rem;
			height: 2.75rem;
			padding: 0.5rem;
			border: 2px solid var(--sl-color-white);
			background: var(--sl-color-black);
			color: var(--sl-color-text-accent);
			box-shadow: 4px 4px 0 var(--sl-color-red);
			transition:
				transform 120ms ease,
				background-color 120ms ease,
				color 120ms ease,
				box-shadow 120ms ease;
		}

		.docs-social-link:hover {
			transform: translate(-2px, -2px);
			background: var(--sl-color-text-accent);
			color: var(--sl-color-black);
			box-shadow: 2px 2px 0 var(--sl-color-red);
		}

		.docs-social-flag {
			display: inline-flex;
			width: clamp(72px, 7vw, 104px);
			margin-top: -1.35rem;
			margin-right: 0.15rem;
			transform-origin: top left;
			animation: flagWave 7s ease-in-out infinite;
		}

		.docs-social-flag img {
			display: block;
			width: 100%;
			height: auto;
		}

		@keyframes flagWave {
			0%, 100% { transform: rotateZ(0deg); }
			50% { transform: rotateZ(8deg); }
		}

		@media (max-width: 50rem) {
			.docs-social-flag {
				width: 68px;
				margin-top: -0.95rem;
			}

			.docs-social-link {
				width: 2.4rem;
				height: 2.4rem;
			}
		}

	}
</style>
