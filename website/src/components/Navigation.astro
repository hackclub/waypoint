---
import { LINKS, IMAGES } from '../config';

export interface Props {
  repoUrl?: string;
  guidesUrl?: string;
  flagSrc?: string;
  flagHref?: string;
}

const {
  repoUrl = LINKS.repo,
  guidesUrl = LINKS.guides,
  flagSrc = IMAGES.orpheusFlag,
  flagHref = LINKS.hackClub
} = Astro.props;    
---

<div class="nav-wrapper">
  <a class="top-left-flag" href={flagHref} aria-label="Hack Club">
    <img src={flagSrc} alt="Hack Club flag" />
  </a>

  <div class="quick-links" aria-label="Quick links">
    <a class="quick-link" href={repoUrl} target="_blank" rel="noreferrer" aria-label="GitHub repository">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.426 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.009-.866-.014-1.699-2.782.605-3.369-1.344-3.369-1.344-.454-1.157-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.004.071 1.532 1.033 1.532 1.033.892 1.53 2.341 1.088 2.91.832.091-.647.349-1.088.635-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.389-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844a9.55 9.55 0 012.504.337c1.909-1.296 2.748-1.026 2.748-1.026.546 1.378.202 2.397.1 2.65.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.31.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.481A10.02 10.02 0 0022 12.017C22 6.484 17.523 2 12 2z"></path>
      </svg>
      <span>Repo</span>
    </a>

    <a class="quick-link" href={guidesUrl} aria-label="Guides">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M6 3h8l4 4v14H6z"></path>
        <path d="M14 3v5h5"></path>
        <path d="M9 12h6"></path>
        <path d="M9 16h6"></path>
      </svg>
      <span>Guides</span>
    </a>
  </div>
</div>

<style>
  .top-left-flag {
    position: fixed;
    top: -20px;
    left: 1rem;
    z-index: 30;
    width: clamp(100px, 12vw, 160px);
    height: auto;
    transform-origin: top left;
    animation: flagWave 7s ease-in-out infinite !important;
  }

  .top-left-flag img {
    width: 100%;
    height: auto;
    display: block;
  }

  .top-left-flag::after {
    display: none;
  }

  .quick-links {
    position: fixed;
    top: 1rem;
    right: 1rem;
    z-index: 30;
    display: flex;
    gap: 0.7rem;
    align-items: center;
    padding: 0.75rem;
    border: 2px solid var(--ink);
    background: var(--bg);
    box-shadow: 6px 6px 0 var(--red);
  }

  .quick-link {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.75rem 0.9rem;
    border: 2px solid var(--ink);
    background: var(--bg);
    transition: transform 120ms ease, background 120ms ease, color 120ms ease;
    font-size: 0.82rem;
    cursor: pointer;
  }

  .quick-link:hover {
    transform: translate(-2px, -2px);
    background: var(--gold);
    color: var(--bg);
  }

  @keyframes flagWave {
    0%, 100% { transform: rotateZ(0deg); }
    50% { transform: rotateZ(8deg); }
  }

  @media (max-width: 900px) {
    .quick-links {
      padding: 0.5rem;
      gap: 0.45rem;
    }

    .quick-link span {
      display: none;
    }
  }

  @media (max-width: 720px) {
    .top-left-flag {
      width: 90px;
      top: -15px;
      left: 0.8rem;
    }

    .quick-links {
      top: 0.8rem;
      right: 0.8rem;
    }
  }

</style>
